{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts && npm --prefix server install",
  "framework": "vite",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 15
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
