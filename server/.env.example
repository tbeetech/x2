# Core
PORT=8080
AUTH_SECRET=change-me-in-production

# Data mode
# When true, the server serves in-memory sample data and skips MongoDB.
USE_SAMPLE_DATA=true

# MongoDB (required when USE_SAMPLE_DATA=false)
MONGODB_URI=mongodb+srv://username:password@cluster-host/Invisphere

# CORS configuration (comma separated list)
CORS_ORIGINS=http://localhost:5173

# Client application URL (used in password reset links)
CLIENT_URL=http://localhost:5173

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=secret
SMTP_FROM=Invisphere Onboarding <onboarding@example.com>

# Console deeplink (optional)
CONSOLE_BASE_URL=https://app.invisphere.com/dashboard
